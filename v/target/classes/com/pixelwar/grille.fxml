<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pixelwar.client.GrilleController"
            style="-fx-background-color: #1a1a2e;"
            prefWidth="820" prefHeight="640">

    <!-- ═══════════════════════════════════════
         HAUT : Bannière de statut (cooldown / embargo)
         Masquée par défaut via init()
         ═══════════════════════════════════════ -->
    <top>
        <HBox fx:id="hboxBanniere" alignment="CENTER" spacing="10" visible="false" managed="false">
            <Label fx:id="labelBanniere" text=""
                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;"/>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════
         GAUCHE : Panneau de contrôle
         ═══════════════════════════════════════ -->
    <left>
        <VBox spacing="0"
              style="-fx-background-color: #16213e; -fx-border-color: #2a2f4e;
                     -fx-border-width: 0 1 0 0;"
              prefWidth="210">

            <!-- En-tête -->
            <Label text="🎨 PIXEL WAR"
                   style="-fx-text-fill: #3A86FF; -fx-font-weight: bold; -fx-font-size: 16;
                          -fx-padding: 18 16 14 16; -fx-border-color: #2a2f4e;
                          -fx-border-width: 0 0 1 0;"/>

            <!-- Section Joueur -->
            <VBox spacing="8" style="-fx-padding: 14 16;">
                <Label text="JOUEUR" style="-fx-text-fill: #4a5568; -fx-font-size: 10; -fx-font-weight: bold;"/>
                <Label fx:id="labelPseudo" text="—"
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Circle fx:id="cercleStatut" radius="6" fill="#888"/>
                    <Label fx:id="labelStatut" text="Inconnu"
                           style="-fx-text-fill: #a8b2d8; -fx-font-size: 12;"/>
                </HBox>
            </VBox>

            <Separator style="-fx-background-color: #2a2f4e;"/>

            <!-- Section Couleur -->
            <VBox spacing="10" style="-fx-padding: 14 16;">
                <Label text="COULEUR" style="-fx-text-fill: #4a5568; -fx-font-size: 10; -fx-font-weight: bold;"/>

                <!-- Couleur sélectionnée : clic pour ouvrir le picker -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      onMouseClicked="#onOuvrirColorPicker"
                      style="-fx-cursor: hand; -fx-background-color: #0d1b3e;
                             -fx-background-radius: 6; -fx-padding: 8;
                             -fx-border-color: #2a3f6f; -fx-border-radius: 6;">
                    <Rectangle fx:id="rectCouleurSelectionnee"
                               width="32" height="32"
                               arcWidth="6" arcHeight="6"
                               fill="#3A86FF" stroke="#555" strokeWidth="1"/>
                    <VBox spacing="2">
                        <Label text="Sélectionnée" style="-fx-text-fill: #4a5568; -fx-font-size: 10;"/>
                        <Label fx:id="labelCouleurSelectionnee" text="#3A86FF"
                               style="-fx-text-fill: #a8b2d8; -fx-font-size: 11; -fx-font-family: monospace;"/>
                    </VBox>
                </HBox>

                <!-- Couleurs récentes -->
                <Label text="RÉCENTES" style="-fx-text-fill: #4a5568; -fx-font-size: 10; -fx-font-weight: bold;"/>
                <HBox fx:id="hboxCouleursRecentes" spacing="5" />

            </VBox>

            <Separator style="-fx-background-color: #2a2f4e;"/>

            <!-- Légende -->
            <VBox spacing="8" style="-fx-padding: 14 16;">
                <Label text="LÉGENDE" style="-fx-text-fill: #4a5568; -fx-font-size: 10; -fx-font-weight: bold;"/>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Rectangle width="14" height="14" arcWidth="3" arcHeight="3"
                               fill="white" stroke="#2a2a2a" strokeWidth="0.5"/>
                    <Label text="Pixel libre" style="-fx-text-fill: #a8b2d8; -fx-font-size: 11;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Rectangle width="14" height="14" arcWidth="3" arcHeight="3"
                               fill="#c0392b" stroke="#FF6B6B" strokeWidth="1.5" opacity="0.85"/>
                    <Label text="Sous embargo (60s)" style="-fx-text-fill: #a8b2d8; -fx-font-size: 11;"/>
                </HBox>
            </VBox>

            <!-- Espace flexible -->
            <Region VBox.vgrow="ALWAYS"/>

            <!-- Bouton déconnexion -->
            <Button fx:id="boutonDeconnexion" text="⏻  Se déconnecter"
                    onAction="#onDeconnexion"
                    maxWidth="Infinity"
                    style="-fx-background-color: #c0392b; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-font-size: 13;
                           -fx-padding: 12; -fx-background-radius: 0; -fx-cursor: hand;">
                <VBox.margin><Insets top="0"/></VBox.margin>
            </Button>

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════
         CENTRE : La grille de pixels
         ═══════════════════════════════════════ -->
    <center>
        <ScrollPane fitToWidth="false" fitToHeight="false"
                    style="-fx-background: #1a1a2e; -fx-background-color: #1a1a2e;">
            <content>
                <VBox alignment="CENTER">
                    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                    <!-- La GridPane est peuplée dynamiquement dans GrilleController.construireGrille() -->
                    <GridPane fx:id="grille" hgap="1" vgap="1"/>
                </VBox>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
